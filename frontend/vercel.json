{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_API_URL": {
      "description": "Backend API URL",
      "value": "https://defi-risk-auditor-backend.up.railway.app"
    },
    "NEXT_PUBLIC_APP_NAME": {
      "description": "Application name",
      "value": "DeFi Risk Auditor"
    },
    "NEXT_PUBLIC_APP_DESCRIPTION": {
      "description": "Application description",
      "value": "TEE-verified DeFi protocol risk analysis with on-chain proof"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://defi-risk-auditor-backend.up.railway.app/api/:path*"
    }
  ]
}